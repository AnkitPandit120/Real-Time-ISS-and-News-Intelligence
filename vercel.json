{
  "rewrites": [
    {
      "source": "/api/iss-position",
      "destination": "http://api.open-notify.org/iss-now.json"
    },
    {
      "source": "/api/astronauts",
      "destination": "http://api.open-notify.org/astros.json"
    },
    {
      "source": "/api/news",
      "destination": "https://api.spaceflightnewsapi.net/v4/articles/?limit=10"
    },
    {
      "source": "/api/reverse-geocode",
      "destination": "https://nominatim.openstreetmap.org/reverse"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
